# PostgreSQL Connection (From Supabase: Settings > Database > Connection String > URI)
# 1. Go to your Supabase Dashboard
# 2. Settings (Gear Icon) > Database
# 3. Scroll down to "Connection String" -> Select "URI"
# 4. Copy the URL and replace [YOUR-PASSWORD] with your database password
# Format: postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SMS API Keys (For real mobile SMS Verification OTPs)
# 1. Twilio Integration (To send actual SMS worldwide)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=12098064687 # Corrected to the user's purchased number

# 2. Infobip Integration (Highly optimized for East Africa / Ethiopia)
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
INFOBIP_SENDER=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
